---
import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';

import { blogListRobots, blogPostsPerPage } from '~/utils/blog';
import { fetchPosts } from '~/utils/blog';
import { BLOG_BASE } from '~/utils/permalinks';

export const prerender = true;

const posts = await fetchPosts();

const perPage = blogPostsPerPage || 6;
const totalPages = Math.ceil(posts.length / perPage);

const paginatedPosts = posts.slice(0, perPage);

const prevUrl = undefined;
const nextUrl = totalPages > 1 ? `/${BLOG_BASE}/2` : undefined;

const metadata = {
  title: 'Blog',
  robots: {
    index: blogListRobots?.index,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline
        subtitle="O wpływie komputerów kwantowych na komunikację cyfrową"
    >
      Blog
    </Headline>
    <BlogList posts={paginatedPosts} />
    <Pagination prevUrl={prevUrl} nextUrl={nextUrl} />
  </section>
</Layout>
